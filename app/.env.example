# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://primpay:primpay@localhost:5432/primpay_dev
DATABASE_URL_TEST=postgresql://primpay:primpay@localhost:5432/primpay_test

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── STRIPE ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_MULTI=price_...

# ─── APPLE WALLET ────────────────────────────────────────────────────────────
APPLE_PASS_TYPE_ID=pass.com.primpay.loyalty
APPLE_TEAM_ID=...
APPLE_CERT_PATH=./certs/apple-wallet.pem
APPLE_CERT_PASSPHRASE=...
APPLE_WWDR_CERT_PATH=./certs/wwdr.pem

# ─── GOOGLE WALLET ───────────────────────────────────────────────────────────
GOOGLE_ISSUER_ID=...
GOOGLE_SERVICE_ACCOUNT_EMAIL=...
GOOGLE_SERVICE_ACCOUNT_KEY=./certs/google-wallet-sa.json

# ─── EMAIL ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@primpay.fr

# ─── SENTRY ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
